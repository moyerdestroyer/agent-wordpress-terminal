{
	"name": "awpt/agent-wordpress-terminal",
	"description": "A WordPress-native terminal for agent-assisted site work.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.2",
		"kucrut/vite-for-wp": "^0.12.0"
	},
	"require-dev": {
		"carthage-software/mago": "^1.42",
		"php-stubs/wordpress-stubs": "^6.8"
	},
	"autoload": {
		"psr-4": {
			"AWPT\\": "src/"
		}
	},
	"config": {
		"sort-packages": true,
		"allow-plugins": {
			"composer/installers": true
		}
	},
	"scripts": {
		"lint": "mago lint",
		"format": "mago format",
		"analyze": "mago analyze",
		"check": ["@lint", "@analyze"]
	}
}
